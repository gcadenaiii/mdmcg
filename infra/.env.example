# RPM PoC — Environment Variables
# Copy this file to .env and edit the values.
#
#   cp .env.example .env

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=rpm
POSTGRES_PASSWORD=CHANGE_ME_in_production
POSTGRES_DB=rpm
DB_PORT=5432

# ── Backend ────────────────────────────────────────────────
BACKEND_PORT=8080
RPM_API_KEY=CHANGE_ME_generate_a_random_key
RPM_DEBUG=false
RPM_ALLOWED_ORIGINS=*

# ── Gateway (set these on the Raspberry Pi) ────────────────
# RPM_GATEWAY_ID=      # auto-generated if not set
# RPM_BACKEND_URL=https://your-lightsail-ip:8080
# RPM_API_KEY=same_key_as_above
# RPM_BLE_DEVICE_NAME=ESP32_BNO055
# RPM_BLE_DEVICE_ADDRESS=
# RPM_SYNC_INTERVAL=10
# RPM_BATCH_SIZE=200
# RPM_STATUS_PORT=8090
