# RPM Gateway Environment File
# Copy this to /home/pi/.rpm_gateway.env and fill in real values.
# This file is never committed to git.

# Lightsail backend URL (no trailing slash)
RPM_BACKEND_URL=http://3.137.160.180:8080

# API key — must match RPM_API_KEY in Lightsail infra/.env
RPM_API_KEY=your-api-key-here

# BLE device name advertised by the ESP32
RPM_BLE_DEVICE_NAME=ESP32_BNO055

# Log level: DEBUG, INFO, WARNING, ERROR
RPM_LOG_LEVEL=INFO

# Optional overrides (defaults shown)
# RPM_SYNC_INTERVAL=10
# RPM_BATCH_SIZE=200
# RPM_STATUS_PORT=8090
